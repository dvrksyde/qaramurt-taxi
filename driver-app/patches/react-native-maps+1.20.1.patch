+- (AIRMapMarker*) markerAtPoint:(CGPoint)point {
+    AIRMapMarker* mrk = nil;
+    for (AIRMapMarker* mrkAnn in self.markers) {
+        CGRect frame = [self frameForMarker:mrkAnn];
