+      return self.camera;
+    } else {
+      return _initialCamera;
+    }
+}
+
+- (void)setCameraProp:(GMSCameraPosition*)camera {
+    if (_isAnimating || !CLLocationCoordinate2DIsValid([camera target])) return;
+    _initialCamera = camera;
+    if(_didLayoutSubviews) {
+      self.camera = camera;
+    }
+}
