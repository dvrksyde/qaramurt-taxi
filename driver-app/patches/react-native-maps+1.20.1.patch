+            key={index}
+            coordinate={overlay.coordinates}
+            tracksViewChanges={pointOverlayTracksViewChanges}
+            image={image}
+            title={title}
+            pinColor={markerColor}
+            zIndex={zIndex}
+            anchor={anchor}
+            centerOffset={centerOffset}
+            onPress={() => onPress && onPress(overlay)}>
+            {markerComponent}
