+- (id)eventFromCoordinate:(CLLocationCoordinate2D)coordinate {
+
+  CGPoint touchPoint = [self.projection pointForCoordinate:coordinate];
+
+  return @{
+           @"coordinate": @{
+               @"latitude": @(coordinate.latitude),
+               @"longitude": @(coordinate.longitude),
+               },
+           @"position": @{
+               @"x": @(touchPoint.x),
+               @"y": @(touchPoint.y),
+               },
+           };
+}
